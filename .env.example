# Secrets for the analyzer. Copy this file to `.env` (which is gitignored) and
# fill in the values. Every script loads `.env` automatically.

# Hackathon site public API key (shared with admins only) — used by scan.py.
HACKATHON_API_KEY=

# Anthropic API key — used by ai/run_ai.py ONLY when ai.provider = "anthropic".
# The default AI provider ("claude_code") runs on your Claude Pro/Max
# subscription via the Claude Code CLI and needs NO API key — sign in with
# `claude` (or `claude setup-token` for headless use) instead. Leave this blank
# unless you switch ai.provider to "anthropic".
ANTHROPIC_API_KEY=
